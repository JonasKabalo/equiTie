# Anthropic API key — needed from Phase 2 onward (the /api/chat endpoint).
# The deterministic engine, dashboard data and tests run WITHOUT a key.
ANTHROPIC_API_KEY=

# Narration model (default: claude-sonnet-4-6 — best balance of quality and cost).
# Lowest cost: claude-haiku-4-5. Best answers: claude-opus-4-8.
ANTHROPIC_MODEL=claude-sonnet-4-6
